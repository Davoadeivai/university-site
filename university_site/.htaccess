# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/cp29524/apps/university_site"
PassengerBaseURI "/"
PassengerPython "/home/cp29524/virtualenv/apps/university_site/3.11/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

PassengerAppEnv production
Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# Serve existing static/media files directly when present on disk
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^static/(.*)$ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^media/(.*)$ - [L]
</IfModule>
