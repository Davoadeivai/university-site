# کپی روی سرور با نام: .env
# دامنه را عوض کنید. این فایل را هرگز در گیت commit نکنید.

SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY
DEBUG=False

# مثال: portal.yourdomain.ir
ALLOWED_HOSTS=SUBDOMAIN.YOURDOMAIN.IR
CSRF_TRUSTED_ORIGINS=https://SUBDOMAIN.YOURDOMAIN.IR

DB_ENGINE=mysql
DB_NAME=REPLACE_DB_NAME
DB_USER=REPLACE_DB_USER
DB_PASSWORD=REPLACE_DB_PASSWORD
DB_HOST=localhost
DB_PORT=3306

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

SMS_ENABLED=False
KAVENEGAR_API_KEY=
SMS_SENDER_NUMBER=
SMS_SITE_LABEL=موسسه آموزش عالی علامه امینی بهنمیر
KAVENEGAR_OTP_TEMPLATE=
OTP_SEND_COOLDOWN=60
OTP_MAX_SEND_PER_HOUR=5
OTP_MAX_VERIFY_ATTEMPTS=5

PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=True

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# معمولاً خالی بگذارید تا از پیش‌فرض settings_prod استفاده شود
STATIC_ROOT=
MEDIA_ROOT=
